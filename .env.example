# Configuración del entorno para el Simulador Lógico
# Copia este archivo como .env y ajusta los valores

# Título de la aplicación (opcional, por defecto "Simulador de Circuitos Lógicos · VHDL")
VITE_APP_TITLE=

# URL base para el deploy (ej: "/simulador-logico/" para GitHub Pages)
VITE_BASE_URL=/

# Google Analytics Measurement ID (opcional, desactivado por defecto)
# Ej: VITE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_ANALYTICS_ID=
