# Configuración del entorno para LogicFlow
# Copia este archivo como .env y ajusta los valores

# Título de la aplicación (opcional)
VITE_APP_TITLE=

# URL base para el deploy (ej: "/logicflow/" para GitHub Pages)
VITE_BASE_URL=/

# Google Analytics Measurement ID (opcional, desactivado por defecto)
# Ej: VITE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_ANALYTICS_ID=

# API REST backend URL (para guardado cloud, auth, etc.)
# Ej: VITE_API_URL=https://api.logicflow.dev
VITE_API_URL=

# GitHub OAuth App — Client ID
# Crea una OAuth App en: https://github.com/settings/developers
# Redirect URI: {VITE_BASE_URL}/auth/github/callback
VITE_GITHUB_CLIENT_ID=

# GitLab OAuth — Client ID
# Crea una aplicación en: https://gitlab.com/-/profile/applications
# Redirect URI: {VITE_BASE_URL}/auth/gitlab/callback
VITE_GITLAB_CLIENT_ID=

# Stripe Publishable Key (para pagos)
# Ej: VITE_STRIPE_PUB_KEY=pk_live_xxxxxxxxxxxxx
VITE_STRIPE_PUB_KEY=

# Supabase / Firebase configuration (opcional, para backend)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=


Gn2W6DCfHEDYkU2V